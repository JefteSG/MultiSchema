# Configurações de ambiente para o MultiSchema

# Ambiente da aplicação (development, production, testing)
FLASK_ENV=development

# Chave secreta para sessões (gerar uma nova para produção)
SECRET_KEY=your-secret-key-change-in-production

# URL do banco de dados principal
# SQLite (desenvolvimento)
DATABASE_URL=sqlite:///sites/master.db

# MySQL/MariaDB (produção)
# DATABASE_URL=mysql+pymysql://user:password@localhost/database

# Caminho para instância Flask
INSTANCE_PATH=/tmp/flask_instance

# Configurações de CORS (origens permitidas)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Debug (apenas desenvolvimento)
FLASK_DEBUG=1